#!/bin/bash

WALLPAPER_DIR=${WALLPAPER_DIR:-$HOME/Fotos/wallpapers}
WALLPAPER_VID_DIR=${WALLPAPER_VID_DIR:-$WALLPAPER_DIR/anim}

LOG_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/wallpaper.log"
declare -a screens
declare -A wallpapers
wallpapers=()

# Cache hyprctl output (called once, reused by all queries)
MONITORS_JSON=""

_help(){
    echo "Usage: w-wallpaper [-x] [-v] [-f] [file ...]"
    echo "  -x  x-mode wallpapers"
    echo "  -v  video wallpapers (not implemented)"
    echo "  -f  force image mode"
    echo "  -h  show this help"
    exit 0
}

_image(){ # : output, img
    local output="$1"
    local img="$2"
    awww img \
        -o "${output//\"}" \
        --transition-type=grow \
        --transition-duration=1.5 \
        --transition-bezier=.13,.82,.45,.86 \
        --transition-pos=.5,.7 \
        "$img"
}

_query_monitor(){
    echo "$MONITORS_JSON" | jq -r "$1"
}

_get_screens(){
    mapfile -t screens < <(_query_monitor '.[].name')
    echo -e "Screens:\n ${screens[*]}" >> "$LOG_FILE"
}

_get_rand_file(){ # screen
    local screen="$1"

    # ask orientation | transform 1:90, 2:180, 3:270 ...
    local orientation
    orientation=$(_query_monitor ".[] | select(.name == \"${screen}\") | .transform")

    # set path
    local DIR
    [[ -n $video ]] && DIR="$WALLPAPER_VID_DIR" || DIR="$WALLPAPER_DIR"
    [[ -n $x_mode ]] && DIR="$DIR/.x"

    # use uw/ subdir for high-res monitors (ultrawide, 4K, etc.)
    # works with both wallpapers/uw/ and wallpapers/.x/uw/
    # Hyprland reports physical (non-rotated) dimensions
    local width
    width=$(_query_monitor ".[] | select(.name == \"${screen}\") | .width")
    if [[ $width -ge 2560 ]] && [[ -d "$DIR/uw" ]]; then
        DIR="$DIR/uw"
    fi

    [[ $orientation == 1 || $orientation == 3 ]] && DIR="$DIR/v"

    # check if dir exists
    if [[ ! -d "$DIR" ]]; then
        echo "NO existe directorio $DIR"
        exit 1
    fi

    # single source of truth: find + mapfile
    local -a files
    mapfile -t files < <(find -L "$DIR" -maxdepth 1 -type f)
    local n_files=${#files[@]}

    if [[ "$n_files" == "0" ]]; then
        echo "No hay wallpapers del tipo seleccionado en $DIR"
        exit 1
    fi

    local rand_file=$(( RANDOM % n_files ))
    echo "n:${n_files}|rand:${rand_file}>${files[$rand_file]}" >> "$LOG_FILE"
    echo "${files[$rand_file]}"
}

_get_wallpapers(){
    _get_screens
    if [[ -n "$*" ]]; then
        local index=0
        unset video
        declare image=1
        for i in "$@"; do
            wallpapers["$index"]="$(realpath "$i")"
            ((index++))
        done
    else
        for i in "${screens[@]}"; do
            wallpapers["$i"]=$(_get_rand_file "$i")
        done
    fi
}

_set_wallpapers(){
    for i in "${!wallpapers[@]}"; do
        _image "$i" "${wallpapers[$i]}"
    done
}

_main(){
    # cache monitor info once
    MONITORS_JSON=$(hyprctl -j monitors list)

    date >> "$LOG_FILE"
    # Create a list of wallpapers
    _get_wallpapers "$@"
    # Set wallpapers
    _set_wallpapers
}

while getopts ':xvfh' OPT; do
    case "${OPT}" in
    x) declare x_mode=1;;
    f) declare image=1 ;;
    v) declare video=1 ;;
    h) _help ;;
    ?) _help ;;
    esac
done

shift $((OPTIND - 1))

_main "$@"
