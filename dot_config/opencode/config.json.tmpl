{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "sos",
  "agent": {
    "sos": {
      "mode": "primary",
      "description": "Orchestrator. Knows all agents, synergies, and workflows. Delegates to specialized agents. Default entry point."
    },
    "vault": {
      "mode": "subagent",
      "description": "Obsidian vault management: navigate, search, create, edit notes, agent journal, session logging, INDEX.md generation."
    },
    "todo": {
      "mode": "subagent",
      "description": "Todoist task management: create, review, prioritize, organize tasks. Eisenhower matrix. Inbox zero. Project overload protection."
    },
    "review": {
      "mode": "subagent",
      "description": "Code reviewer. Reviews code for quality, security, refactoring, testing. Gives actionable feedback."
    },
    "arch": {
      "mode": "subagent",
      "description": "Infrastructure advisor. AWS architecture, Well-Architected, best practices, cost and security review. Advises, does not implement."
    },
    "code": {
      "mode": "all",
      "description": "Developer. Writes code, implements features, debugging, problem solving."
    },
    "config": {
      "mode": "all",
      "description": "Arch Linux system configuration. Dotfiles, chezmoi, packages, shell, Hyprland."
    },
    "teach": {
      "mode": "primary",
      "description": "Mentor. Socratic method, challenges to think deeper. AWS certs, concept mastery. Interactive learning."
    }
  },
  "mcp": {
    "personal-planner": {
      "type": "local",
      "command": [
        "{{ .chezmoi.homeDir }}/.agents/daily-planner-mcp/.venv/bin/python",
        "-m",
        "personal_planner_mcp"
      ],
      "environment": {
        "VAULT_PATH": "{{ .chezmoi.homeDir }}/A-Mann"
      },
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "@mauricio.wolff/mcp-obsidian@latest",
        "{{ .chezmoi.homeDir }}/A-Mann"
      ],
      "enabled": true
    },
    "todoist": {
      "type": "local",
      "command": [
        "npx",
        "@doist/todoist-ai"
      ],
      "environment": {
        "TODOIST_API_KEY": {{ (bitwarden "item" "b4dbd09d-450c-486a-8721-b29c007834d4" ).notes | quote }}
      },
      "enabled": true
    }
  }
}
