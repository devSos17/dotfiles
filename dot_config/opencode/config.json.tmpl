{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "{{ if eq .chezmoi.os "darwin" }}racker{{ else }}sos{{ end }}",
  "agent": {
    "sos": {
      "mode": "primary",
      "description": "Orchestrator. Knows all agents, synergies, and workflows. Delegates to specialized agents. Default entry point."
    },
    "vault": {
      "mode": "subagent",
      "description": "Obsidian vault management: navigate, search, create, edit notes, agent journal, session logging, INDEX.md generation."
    },
    "todo": {
      "mode": "subagent",
      "description": "Todoist task management: create, review, prioritize, organize tasks. Eisenhower matrix. Inbox zero. Project overload protection."
    },
    "review": {
      "mode": "subagent",
      "description": "Code reviewer. Reviews code for quality, security, refactoring, testing. Gives actionable feedback."
    },
    "arch": {
      "mode": "subagent",
      "description": "Infrastructure advisor. AWS architecture, Well-Architected, best practices, cost and security review. Advises, does not implement."
    },
{{ if eq .chezmoi.os "darwin" }}
    "racker": {
      "mode": "primary",
      "description": "Work orchestrator. Plans implementations for Rackspace clients, creates context for Kiro, breaks down tasks. Focuses on design and planning."
    },
    "doc": {
      "mode": "subagent",
      "description": "Deliverables. Commits, JIRA comments, Confluence pages, Teams messages. Packages work output for delivery."
    },
    "config-mac": {
      "mode": "all",
      "description": "macOS system configuration. Dotfiles, chezmoi, packages, shell, Homebrew."
    },
{{ else }}
    "config": {
      "mode": "all",
      "description": "Arch Linux system configuration. Dotfiles, chezmoi, packages, shell, Hyprland."
    },
{{ end }}
    "code": {
      "mode": "all",
      "description": "Developer. Writes code, implements features, debugging, problem solving."
    },
    "teach": {
      "mode": "primary",
      "description": "Mentor. Socratic method, challenges to think deeper. AWS certs, concept mastery. Interactive learning."
    }
  },
  "mcp": {
    "personal-planner": {
      "type": "local",
      "command": [
        "{{ .chezmoi.homeDir }}/.agents/daily-planner-mcp/.venv/bin/python",
        "-m",
        "personal_planner_mcp"
      ],
      "environment": {
        "VAULT_PATH": "{{ .chezmoi.homeDir }}/A-Mann"
      },
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "@mauricio.wolff/mcp-obsidian@latest",
        "{{ .chezmoi.homeDir }}/A-Mann"
      ],
      "enabled": true
    },
    "todoist": {
      "type": "local",
      "command": [
        "npx",
        "@doist/todoist-ai"
      ],
      "environment": {
        "TODOIST_API_KEY": "{env:TODOIST_API_KEY}"
      },
      "enabled": true
    }{{ if eq .chezmoi.os "darwin" }},
    "atlassian": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "{{ .chezmoi.homeDir }}/.agents/mcp-atlassian",
        "mcp-atlassian"
      ],
      "environment": {
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_EMAIL": "{env:JIRA_EMAIL}",
        "JIRA_TOKEN": "{env:JIRA_TOKEN}",
        "ALLOWED_PROJECTS": "{env:ALLOWED_PROJECTS}",
        "JIRA_STORY_POINTS_FIELD": "customfield_10004"
      },
      "enabled": true
    }{{ end }}
  }
}
