alias cm=chezmoi
# Cache completions to fpath instead of eval on every shell (~57ms saved)
# Regenerates when chezmoi version changes or file is missing
if [[ ! -f "${XDG_HOME_CONFIG:-$HOME/.config}/zsh/completion/_chezmoi" ]]; then
    mkdir -p "${XDG_HOME_CONFIG:-$HOME/.config}/zsh/completion"
    chezmoi completion zsh > "${XDG_HOME_CONFIG:-$HOME/.config}/zsh/completion/_chezmoi" 2>/dev/null
fi
