# Cheap: set env vars and PATH immediately
export PATH="$HOME/.pyenv/bin:$PATH"
export PYENV_VIRTUALENV_DISABLE_PROMPT=1

# Lazy load: defer pyenv init until first use
_load_pyenv() {
  # Remove all wrapper functions first
  unfunction pyenv python python3 pip pip3 2>/dev/null

  eval "$(pyenv init --path)"
  eval "$(pyenv init -)"
  eval "$(pyenv virtualenv-init -)"
}

# Wrapper functions that trigger lazy load on first call
for _pyenv_cmd in pyenv python python3 pip pip3; do
  eval "${_pyenv_cmd}() { _load_pyenv; ${_pyenv_cmd} \"\$@\" }"
done
unset _pyenv_cmd
