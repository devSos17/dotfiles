# Eager: env vars + shims PATH (direct, no subprocess)
export PATH="$HOME/.pyenv/shims:$HOME/.pyenv/bin:$PATH"
export PYENV_VIRTUALENV_DISABLE_PROMPT=1
# Background rehash — keeps shims current without blocking shell startup
command pyenv rehash &!

# Lazy: defer full shell integration until first pyenv use
_load_pyenv() {
  unfunction pyenv 2>/dev/null
  eval "$(pyenv init -)"
  eval "$(pyenv virtualenv-init -)"
}

pyenv() { _load_pyenv; pyenv "$@" }
