# Bitwarden secret loader
# Engine only — secret definitions live in ~/.config/secrets/{service}
# Format per file: ENV_VAR_NAME bitwarden-item-name [field-name] (one per line)
# field-name defaults to "token" if omitted

# 1. Source plain env files (always)
for envfile in {{ .chezmoi.homeDir }}/.config/shell/env/*; do
    [ -f "$envfile" ] && . "$envfile"
done

# 2. Load secrets from Bitwarden (only if available)
_bw_load_secrets() {
    command -v bw >/dev/null 2>&1 || return 0
    [ -z "$BW_SESSION" ] && return 0

    local bw_status
    bw_status=$(bw status 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null)
    [ "$bw_status" = "unlocked" ] || return 0

    # Read a custom field from a Bitwarden Secure Note
    _bw_field() {
        local item="$1" field="${2:-token}"
        bw get item "$item" 2>/dev/null | python3 -c "
import sys,json
fields = json.load(sys.stdin).get('fields') or []
print(next((f['value'] for f in fields if f['name'] == '$field'), ''))" 2>/dev/null
    }

    # Loop through secret definition files
    local var_name bw_item field_name val
    for secretfile in {{ .chezmoi.homeDir }}/.config/secrets/*; do
        [ -f "$secretfile" ] || continue
        while read -r var_name bw_item field_name; do
            [ -z "$var_name" ] && continue
            [[ "$var_name" = \#* ]] && continue
            val=$(_bw_field "$bw_item" "${field_name:-token}")
            [ -n "$val" ] && export "$var_name=$val"
        done < "$secretfile"
    done

    unset -f _bw_field
}

_bw_load_secrets
unset -f _bw_load_secrets
