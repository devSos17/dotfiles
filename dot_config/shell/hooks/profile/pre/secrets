# Bitwarden secret loader (login shell only)
# Loads secrets from Bitwarden and pushes to tmux server env.
# Definitions: ~/.config/secrets/{service} — format: ENV_VAR bw-item [field]
# Shared helpers: ~/.config/shell/lib/bw-helpers.sh

_bw_load_and_push() {
    command -v bw >/dev/null 2>&1 || return 1
    [ -z "$BW_SESSION" ] && return 1

    local bw_status
    bw_status=$(bw status 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null)
    [ "$bw_status" = "unlocked" ] || return 1

    # Source shared helpers
    local helpers="$HOME/.config/shell/lib/bw-helpers.sh"
    [ -f "$helpers" ] || return 1
    . "$helpers"

    local var_name bw_item field_name val
    for secretfile in "$HOME/.config/secrets/"*; do
        [ -f "$secretfile" ] || continue
        while read -r var_name bw_item field_name; do
            [ -z "$var_name" ] && continue
            [[ "$var_name" = \#* ]] && continue
            val=$(bw_field "$bw_item" "${field_name:-token}")
            if [ -n "$val" ]; then
                export "$var_name=$val"
                # Push to tmux server if running
                command -v tmux >/dev/null 2>&1 && tmux setenv "$var_name" "$val" 2>/dev/null
            fi
        done < "$secretfile"
    done

    return 0
}

if _bw_load_and_push; then
    # Set sentinel so tmux session-created hook knows secrets are already loaded
    command -v tmux >/dev/null 2>&1 && tmux setenv SECRETS_LOADED true 2>/dev/null
fi
unset -f _bw_load_and_push
