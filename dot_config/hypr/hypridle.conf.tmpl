general {
    lock_cmd = pidof hyprlock || hyprlock       # avoid starting multiple hyprlock instances.
    before_sleep_cmd = loginctl lock-session    # lock before suspend. (El kill de Brave se quitó: el fix real fue SuspendState=mem en sleep.conf, no la muleta.)
    after_sleep_cmd = hyprctl dispatch dpms on  # to avoid having to press a key twice to turn on the display.
    # ignore_dbus_inhibit = true # Even if video is playing or else
}

{{- if eq .chezmoi.hostname "ronin" }}
listener {
    timeout = 150 # 2.5min.
    on-timeout = brightnessctl -s set 10 # set monitor backlight to minimum, avoid 0 on OLED monitor.
    on-resume = brightnessctl -r # monitor backlight restor.
}

# Asus kbd_backlight
listener { 
    timeout = 10
    on-timeout = brightnessctl -sd  asus::kbd_backlight set 0
    on-resume = brightnessctl -rd asus::kbd_backlight
}

listener {
    timeout = 270 # 4:70 Min 
    on-timeout = notify-send "Se bloqueará el sistema en 30s"
}

listener {
    timeout = 300 # 5min
    on-timeout = loginctl lock-session # lock screen when timeout has passed
}

listener {
    timeout = 380 # 6m20s
    on-timeout = hyprctl dispatch dpms off # screen off when timeout has passed
    on-resume = hyprctl dispatch dpms on # screen on when activity is detected after timeout has fired.
}

listener {
    timeout = 1800 # 30min
    on-timeout = systemctl suspend # suspend pc
}

{{- else }}

listener {
    timeout = 570 # 9:30 Min 
    on-timeout = notify-send "Se bloqueará el sistema en 30s"
}

# DPMS off en idle desactivado intencionalmente: la RX 7900 GRE se degrada en
# cada ciclo S3 y el auto-suspend desatendido colgó la máquina (hard power-off).
# Para re-activar el apagado automático de pantallas, descomenta el listener de abajo.
# listener {
#     timeout = 600 # 10min
#     on-timeout = hyprctl dispatch dpms off
#     on-resume = hyprctl dispatch dpms on
# }

listener {
    timeout = 870 # 14:30 Min
    on-timeout = notify-send "Se bloqueará el sistema en 30s"
}

listener {
    timeout = 900 # 15min
    on-timeout = loginctl lock-session # lock screen when timeout has passed
}

# Auto-suspend desactivado intencionalmente: el usuario suspende manualmente.
# (Causa raíz del cuelgue ya resuelta con SuspendState=mem en /etc/systemd/sleep.conf.d/;
#  re-activar el auto-suspend de abajo ya debería ser seguro si se quiere.)
# Para re-activar, descomenta el listener de abajo.
# listener {
#     timeout = 1800 # 30min
#     on-timeout = systemctl suspend
# }

{{- end }}
