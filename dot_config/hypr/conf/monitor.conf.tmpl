# See https://wiki.hyprland.org/Configuring/Monitors/
# Monitor configuration is managed by kanshi. Only fallback rules here.
# Static monitor definitions conflict with kanshi profile switches (scale, position).

{{ if eq .chezmoi.hostname "ronin" -}}
# Ronin: mirror unknown monitors to eDP-1
monitor=,preferred,auto,1,mirror,eDP-1

# Integrated display — 120Hz causes visual glitches, use 100Hz
monitor=eDP-1,1920x1080@100,0x0,1.2

{{ else -}}
# Fallback for any unknown/hotplugged monitor
monitor=,preferred,auto,1

{{ end }}
