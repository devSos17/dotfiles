{
  "agent": "{{ if eq .chezmoi.os "darwin" }}racker{{ else }}sos{{ end }}",
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "obsidian": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@mauricio.wolff/mcp-obsidian@latest", "{{ .chezmoi.homeDir }}/A-Mann"]
    },
    "todoist": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@doist/todoist-ai"],
      "env": {
        "TODOIST_API_KEY": "${TODOIST_API_KEY}"
      }
    }{{ if eq .chezmoi.os "darwin" }},
    "atlassian": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "{{ .chezmoi.homeDir }}/.agents/mcp-atlassian",
        "mcp-atlassian"
      ],
      "env": {
        "JIRA_URL": "${JIRA_URL}",
        "JIRA_EMAIL": "${JIRA_EMAIL}",
        "JIRA_TOKEN": "${ATLASSIAN_TOKEN}",
        "CONFLUENCE_URL": "https://corpinfollc.atlassian.net",
        "CONFLUENCE_EMAIL": "santiago.orozco@rackspace.com",
        "CONFLUENCE_TOKEN": "${ATLASSIAN_TOKEN}",
        "ALLOWED_PROJECTS": "${ALLOWED_PROJECTS}",
        "JIRA_STORY_POINTS_FIELD": "customfield_10004"
      }
    }{{ end }}
  }
}
